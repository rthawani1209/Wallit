# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# --- Postgres ---
POSTGRES_DB=wallit
POSTGRES_USER=wallit
POSTGRES_PASSWORD=wallit_dev_password
DATABASE_URL=postgresql://wallit:wallit_dev_password@postgres:5432/wallit

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT auth ---
# Generate a real secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Plaid (sandbox) ---
# Sign up free at https://dashboard.plaid.com
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-secret
PLAID_ENV=sandbox

# --- Encryption key for Plaid access tokens stored in DB ---
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
